
# Suppressions for Darwin 17.x / macOS 10.13 High Sierra

############################################
## Leaks.  For other stuff see below.

{
   OSX1013:1-Leak
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc_zone_?alloc
   ...
   fun:_read_images
}

{
   OSX1013:2-Leak
   Memcheck:Leak
   match-leak-kinds: all
   fun:malloc_zone_?alloc
   ...
   fun:_read_images
}

{
   OSX1013:3-Leak
